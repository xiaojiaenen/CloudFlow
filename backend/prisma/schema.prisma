generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  pending
  running
  success
  failed
  cancelled
}

enum TaskTriggerSource {
  manual
  schedule
}

enum TaskExecutionEventType {
  log
  screenshot
  status
  extract
}

model Workflow {
  id               String   @id @default(cuid())
  name             String
  description      String?
  definition       Json
  scheduleEnabled  Boolean  @default(false)
  scheduleCron     String?
  scheduleTimezone String?
  alertEmail       String?
  alertOnSuccess   Boolean  @default(false)
  alertOnFailure   Boolean  @default(false)
  tasks            Task[]
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([scheduleEnabled])
  @@index([deletedAt])
}

model Task {
  id                String               @id @default(cuid())
  workflowId        String
  workflow          Workflow             @relation(fields: [workflowId], references: [id])
  status            TaskStatus           @default(pending)
  triggerSource     TaskTriggerSource    @default(manual)
  workflowSnapshot  Json
  errorMessage      String?
  cancelRequestedAt DateTime?
  executionEvents   TaskExecutionEvent[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?

  @@index([workflowId])
  @@index([status])
}

model TaskExecutionEvent {
  id          String                 @id @default(cuid())
  taskId       String
  task         Task                   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type         TaskExecutionEventType
  sequence     Int
  level        String?
  nodeId       String?
  message      String?                @db.Text
  status       TaskStatus?
  mimeType     String?
  imageBase64  String?                @db.LongText
  payload      Json?
  createdAt    DateTime               @default(now())

  @@index([taskId, createdAt])
  @@index([taskId, sequence])
  @@index([taskId, type])
}
