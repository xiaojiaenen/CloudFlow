generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  pending
  running
  success
  failed
  cancelled
}

enum TaskTriggerSource {
  manual
  schedule
}

enum TaskExecutionEventType {
  log
  screenshot
  status
  extract
}

enum WorkflowLifecycleStatus {
  draft
  active
  archived
}

enum UserRole {
  admin
  user
}

enum UserStatus {
  active
  suspended
}

model Workflow {
  id               String   @id @default(cuid())
  ownerId          String
  owner            User     @relation("UserWorkflows", fields: [ownerId], references: [id])
  name             String
  description      String?
  definition       Json
  status           WorkflowLifecycleStatus @default(active)
  scheduleEnabled  Boolean  @default(false)
  scheduleCron     String?
  scheduleTimezone String?
  alertEmail       String?
  alertOnSuccess   Boolean  @default(false)
  alertOnFailure   Boolean  @default(false)
  tasks            Task[]
  publishedTemplates WorkflowTemplate[] @relation("WorkflowPublishedTemplates")
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ownerId])
  @@index([scheduleEnabled])
  @@index([deletedAt])
  @@index([status])
}

model Task {
  id                String               @id @default(cuid())
  workflowId        String
  workflow          Workflow             @relation(fields: [workflowId], references: [id])
  ownerId           String
  owner             User                 @relation("UserTasks", fields: [ownerId], references: [id])
  status            TaskStatus           @default(pending)
  triggerSource     TaskTriggerSource    @default(manual)
  queuePriority     Int                  @default(1)
  workflowSnapshot  Json
  errorMessage      String?
  cancelRequestedAt DateTime?
  tempDir           String?
  workerPid         Int?
  resourceHeartbeatAt DateTime?
  memoryRssMb       Float?
  peakMemoryRssMb   Float?
  heapUsedMb        Float?
  peakHeapUsedMb    Float?
  cpuPercent        Float?
  peakCpuPercent    Float?
  executionEvents   TaskExecutionEvent[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?

  @@index([ownerId])
  @@index([workflowId])
  @@index([status])
}

model TaskExecutionEvent {
  id          String                 @id @default(cuid())
  taskId       String
  task         Task                   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type         TaskExecutionEventType
  sequence     Int
  level        String?
  nodeId       String?
  message      String?                @db.Text
  status       TaskStatus?
  mimeType     String?
  imageBase64  String?                @db.LongText
  storageProvider String?
  storageBucket String?
  storageKey   String?
  sizeBytes    Int?
  payload      Json?
  createdAt    DateTime               @default(now())

  @@index([taskId, createdAt])
  @@index([taskId, sequence])
  @@index([taskId, type])
}

model WorkflowTemplate {
  id               String    @id @default(cuid())
  slug             String    @unique
  sourceWorkflowId String?
  sourceWorkflow   Workflow? @relation("WorkflowPublishedTemplates", fields: [sourceWorkflowId], references: [id])
  publisherId      String?
  publisher        User?     @relation("PublishedTemplates", fields: [publisherId], references: [id])
  title            String
  description      String    @db.Text
  category         String
  tags             Json
  definition       Json
  authorName       String    @default("CloudFlow")
  published        Boolean   @default(false)
  featured         Boolean   @default(false)
  installCount     Int       @default(0)
  rating           Float     @default(4.8)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([sourceWorkflowId])
  @@index([publisherId])
  @@index([published, deletedAt])
  @@index([category])
}

model SystemConfig {
  id                   String   @id @default(cuid())
  platformName         String   @default("CloudFlow")
  supportEmail         String?
  smtpHost             String?
  smtpPort             Int      @default(587)
  smtpUser             String?
  smtpPass             String?
  smtpSecure           Boolean  @default(false)
  smtpFrom             String?
  minioEndpoint        String?
  minioPort            Int      @default(9000)
  minioUseSSL          Boolean  @default(false)
  minioAccessKey       String?
  minioSecretKey       String?
  minioBucket          String?  @default("cloudflow-task-artifacts")
  screenshotIntervalMs Int      @default(500)
  screenshotPersistIntervalMs Int @default(3000)
  taskRetentionDays    Int      @default(30)
  monitorPageSize      Int      @default(10)
  globalTaskConcurrency Int     @default(2)
  perUserTaskConcurrency Int    @default(1)
  manualTaskPriority   Int      @default(1)
  scheduledTaskPriority Int     @default(10)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  passwordHash       String
  role               UserRole           @default(user)
  status             UserStatus         @default(active)
  workflows          Workflow[]         @relation("UserWorkflows")
  tasks              Task[]             @relation("UserTasks")
  publishedTemplates WorkflowTemplate[] @relation("PublishedTemplates")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([role, status])
}
