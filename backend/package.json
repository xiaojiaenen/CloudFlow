{
  "name": "backend",
  "version": "1.0.0",
  "description": "CloudFlow backend powered by NestJS, BullMQ, Redis, Prisma and Playwright.",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/src/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "worker": "ts-node -r tsconfig-paths/register worker/worker.ts",
    "worker:prod": "node dist/worker/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "ownership:backfill": "ts-node -r tsconfig-paths/register scripts/backfill-ownership.ts"
  },
  "keywords": [
    "cloudflow",
    "nestjs",
    "bullmq",
    "playwright"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "@prisma/client": "^6.17.1",
    "@types/nodemailer": "^7.0.11",
    "bullmq": "^5.71.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "minio": "^8.0.7",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.4",
    "playwright": "^1.58.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "prisma": "^6.17.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
