# ──── 必填 ──────────────────────────────────────
# 数据库连接 (MySQL)
DATABASE_URL=mysql://cloudflow:your-password@mysql-host:3306/cloudflow

# Redis 连接
REDIS_URL=redis://redis-host:6379

# ──── 可选 ──────────────────────────────────────
# Redis 模式: standalone | cluster (默认 standalone)
# REDIS_MODE=standalone
# REDIS_CLUSTER_NODES=
# REDIS_PASSWORD=
# REDIS_TLS=false
# REDIS_BULL_PREFIX=

# 前端地址（用于跨域配置）
# FRONTEND_BASE_URL=http://localhost:10003

# 超级管理员邮箱（逗号分隔）
# SUPER_ADMIN_EMAILS=admin@cloudflow.local

# Worker 并发数
# WORKER_CONCURRENCY=2

# 浏览器模式
# BROWSER_HEADLESS=true

# 是否默认种子用户
# SEED_DEFAULT_USERS=false

# ──── 邮件通知（可选） ───────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# SMTP_FROM=

# ──── 对象存储 MinIO（可选） ──────────────────────
# MINIO_ENDPOINT=
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=cloudflow-task-artifacts

# ──── 镜像构建 ──────────────────────────────────
# NPM 源（内网可改为私有源）
# NPM_REGISTRY=https://registry.npmjs.org

# Playwright 镜像
# PLAYWRIGHT_IMAGE=mcr.microsoft.com/playwright:v1.58.2-noble

# ──── 端口 ──────────────────────────────────────
# 后端端口
# BACKEND_PORT=10004

# 前端端口
# FRONTEND_PORT=10003
